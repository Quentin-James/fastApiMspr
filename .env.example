# Application
APP_ENV=development
APP_PORT=8085

# MongoDB
MONGODB_URL=mongodb://localhost:27017
MONGODB_DB_NAME=mspr_ia

# MySQL comptes utilisateurs
MYSQL_DATABASE_URL=mysql+pymysql://mspr:mspr@mysql:3306/mspr_users

# Hugging Face
HUGGINGFACE_API_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
HUGGINGFACE_FOOD_MODEL=google/vit-base-patch16-224

# Google Vision API
GOOGLE_VISION_API_KEY=AIzaSyXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Backend Spring Boot (pour récupérer les données nutritionnelles PostgreSQL)
SPRING_BACKEND_URL=http://localhost:8080

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080

# Rate limiting
RATE_LIMIT=10/minute
